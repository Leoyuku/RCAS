# ╔══════════════════════════════════════════════════════════════╗
# ║              RCAS Backend 配置文件模板                        ║
# ║  使用方法：复制此文件为 .env，按实际情况修改后保存              ║
# ╚══════════════════════════════════════════════════════════════╝

# ── 运行环境 ──────────────────────────────────────────────────────
# production | development
NODE_ENV=production

# ── HTTP 服务器 ───────────────────────────────────────────────────
PORT=3000

# ── 日志级别 ──────────────────────────────────────────────────────
# error | warn | info | debug
# 生产环境建议 info，调试时改为 debug
LOG_LEVEL=info

# ── MOS 设备身份 ──────────────────────────────────────────────────
# 本设备在 MOS 网络中的唯一标识，需与 NCS 系统中配置的 MOS ID 一致
MOS_ID=rcas.mos

# 设备序列号（在 reqMachInfo 响应中返回给 NCS）
MOS_SERIAL=SN-RCAS-001

# ── MOS 监听端口（本机接受 NCS 连接）────────────────────────────
# 标准 MOS 端口，一般不需要修改
# 如有端口冲突（如同机运行多个 MOS 实例）才需要修改
MOS_PORT_LOWER=10540
MOS_PORT_UPPER=10541
MOS_PORT_QUERY=10542

# ── 联调/测试模式（主动连接对端）────────────────────────────────
# 生产环境下注释掉以下所有 MOS_CONNECT_* 变量
# NCS 会主动连接到我们，不需要我们主动连接
#
# 开发/联调时（如连接 quick-mos）取消注释并填写：
# MOS_CONNECT_HOST=127.0.0.1
# MOS_CONNECT_ID=quick.mos
# MOS_CONNECT_PORT_LOWER=11540
# MOS_CONNECT_PORT_UPPER=11541
# MOS_CONNECT_PORT_QUERY=11542